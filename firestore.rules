rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - fullName: string - User full name
    //   - companyName: string - User company name
    //   - phone: string - User phone number
    //   - role: string (required) - "buyer", "supplier", or "admin"
    //   - points: number - User points
    //   - referralCode: string - User referral code
    //   - referredBy: string - User referred by code
    //   - sector: string - User sector
    //   - address: string - User address
    //   - isActive: bool - User active status
    //   - createdAt: timestamp - Creation date
    //
    // Collection: groupBuys
    // Document ID: {groupBuyId}
    // Fields:
    //   - creatorId: string (required) - Creator UID
    //   - productName: string (required) - Product name
    //   - category: string (required) - Product category
    //   - description: string - Product description
    //   - unit: string - Product unit
    //   - unitPrice: number (required) - Unit price
    //   - targetQuantity: number (required) - Target quantity
    //   - currentQuantity: number - Current quantity
    //   - targetPrice: number - Target total price
    //   - imagesBase64: string - JSON string of images
    //   - status: string - "active", "completed", "cancelled"
    //   - deadline: timestamp - Expiration date
    //   - createdAt: timestamp - Creation date
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - groupBuyId: string (required) - Group buy ID
    //   - userId: string (required) - User UID
    //   - quantity: number (required) - Order quantity
    //   - status: string - "pending", "confirmed", "cancelled"
    //   - createdAt: timestamp - Creation date
    //   - updatedAt: timestamp - Last update date
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - userId: string (required) - User UID
    //   - title: string (required) - Notification title
    //   - message: string (required) - Notification message
    //   - link: string - Notification link
    //   - isRead: bool - Read status
    //   - createdAt: timestamp - Creation date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "ozerbaser@gmail.com"
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['buyer', 'supplier', 'admin'];
    }

    function isValidGroupBuy(data) {
      return data.keys().hasAll(['productName', 'category', 'unitPrice', 'targetQuantity', 'creatorId']) &&
             data.productName is string && data.productName.size() > 0 && data.productName.size() < 200 &&
             data.category is string &&
             data.unitPrice is number && data.unitPrice > 0 &&
             data.targetQuantity is number && data.targetQuantity > 0 &&
             data.creatorId is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['groupBuyId', 'userId', 'quantity']) &&
             data.groupBuyId is string &&
             data.userId is string &&
             data.quantity is number && data.quantity > 0;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading other users for notifications/suppliers check
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /groupBuys/{groupBuyId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidGroupBuy(request.resource.data) && (request.resource.data.creatorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidGroupBuy(request.resource.data) && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || 
                   get(/databases/$(database)/documents/groupBuys/$(resource.data.groupBuyId)).data.creatorId == request.auth.uid || 
                   isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || 
                    get(/databases/$(database)/documents/groupBuys/$(resource.data.groupBuyId)).data.creatorId == request.auth.uid || 
                    isAdmin());
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
